  scope-check:
    name: Detect Changed IAC Files
    runs-on: mmc-ubuntu
    outputs:
      should_run: ${{ steps.check.outputs.should_run }}
      iac_files: ${{ steps.check.outputs.iac_files }}
    steps:
      - name: Checkout Source Code repo
        uses: actions/checkout@v4
        with:
          ref: ${{ github.event.client_payload.checkout_sha || github.head_ref || github.event.pull_request.head.ref || github.ref_name }}
          fetch-depth: 2

      - name: Check IAC files and changes
        id: check
        shell: bash
        run: |
          if [ ! -d ".iac" ]; then
            echo ".iac folder is not present. Exiting workflow."
            echo "should_run=false" >> "$GITHUB_OUTPUT"
            echo "iac_files=[]" >> "$GITHUB_OUTPUT"
            exit 0
          fi

          AFTER_SHA="${{ github.sha }}"
          CHANGED_FILES="$(git show --pretty='' --name-only "$AFTER_SHA" | sed '/^$/d')"

          NON_IAC_FILE="$(echo "$CHANGED_FILES" | grep -v '^\.iac/' | head -n 1 || true)"
          if [ -n "$NON_IAC_FILE" ]; then
            echo "Current commit includes non-.iac changes ($NON_IAC_FILE). Exiting workflow."
            echo "should_run=false" >> "$GITHUB_OUTPUT"
            echo "iac_files=[]" >> "$GITHUB_OUTPUT"
            exit 0
          fi

          DEV_IAC_FILES="$(echo "$CHANGED_FILES" | grep -E '^\.iac/dev-.*\.(iac|yaml)$' || true)"
          if [ -z "$DEV_IAC_FILES" ]; then
            echo "No dev-* .iac file changes detected. Exiting workflow."
            echo "should_run=false" >> "$GITHUB_OUTPUT"
            echo "iac_files=[]" >> "$GITHUB_OUTPUT"
            exit 0
          fi

          IAC_JSON=$(echo "$DEV_IAC_FILES" | jq -R -s -c 'split("\n") | map(select(length > 0))')
          echo "Detected dev- IAC files: $IAC_JSON"
          echo "iac_files=$IAC_JSON" >> "$GITHUB_OUTPUT"
          echo "should_run=true" >> "$GITHUB_OUTPUT"

