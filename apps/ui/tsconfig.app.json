{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../dist/out-tsc",
        "types": ["node"],
        "resolveJsonModule": true,
        "moduleResolution": "bundler"
    },
    "files": ["src/main.ts", "src/polyfills.ts"],
    "include": ["src/**/*.ts", "src/**/*.d.ts"],
    "exclude": ["src/test-setup.ts", "src/**/*.spec.ts", "src/**/*.test.ts"]
}
