{
    "$schema": "../../node_modules/@angular/service-worker/config/schema.json",
    "index": "/index.html",
    "assetGroups": [
        {
            "name": "app-shell",
            "installMode": "prefetch",
            "resources": {
                "files": ["/index.html", "/*.css", "/*.js", "/favicon.ico"]
            }
        },
        {
            "name": "static-assets",
            "installMode": "lazy",
            "updateMode": "prefetch",
            "resources": {
                "files": ["/assets/**"]
            }
        }
    ]
}
