
CHART_NAME=webservice
CHART_VERSION=1.0.73

APP_TYPE=api
CREATE_SVC_ACCOUNT=true
APP_NAMESPACE=mer-operdash-dev-operationaldashboard
APP_RELEASENAME=api
APP_CONTEXT_PATH= /api
HEALTH_CHECK_URI=/v1/health
API_PORT_NUMBER=8080
KUBERNETES_URL=https://mgti-dallas-rancher.mrshmc.com/k8s/clusters/c-fdfwk
HOSTNAME=dev-operational-dashboard.int.npd.mmc.aws-euw1.oss2.mrshmc.com
SECRETS_URL=https://mgti-dal-so-vlt.mrshmc.com/v1/secrets/config
VAULT_URL=https://mgti-dal-so-vlt.mrshmc.com/v1/auth/aws-mmc-app-npd-eks-euw1-int/login
VAULT_NAMESPACE=mmc-app-npd-eks-euw1-int/mer-operdash-dev-operationaldashboard
VAULT_ROLE_NAME=eks-mer-operdash-dev-operationaldashboard-3abd
API_DATASTORE_NAME=app
KUBERNETES_SERVICE_ACCOUNT_NAME=mgti-dvpseng-stg-oss2helloworld-svc-acct
KUBERNETES_CLUSTER=mmc-app-npd-eks-euw1-int


AWS_ROLE_ARN=arn:aws:iam::231305351765:role/eks-mer-operdash-dev-operationaldashboard-3abd
VAULT_AWS_REGION=eu-west-1
VAULT_AWS_AUTH_BACKEND=aws-mmc-app-npd-eks-euw1-int
VAULT_ADDR=https://mgti-dal-so-vlt.mrshmc.com
VAULT_USE_AWS_AUTH=true



NODE_AFFINITY_KEY=type
NODE_AFFINITY_VALUE=app


#For more information on this section, please refer to Platform standards here https://mmcglobal.sharepoint.com/:u:/r/sites/OpenSourceStack/SitePages/Container-Pod-Labels-and-Annotations.aspx?csf=1&web=1&e=aPvqoy
APP_TIER=application
TIER=application
IS_POLARIS=true

JFROG_PROD_REPO=prod-images.mgti-dal-so-art.mrshmc.com

#For more information on this section, please refer to Platform standards here https://mmcglobal.sharepoint.com/sites/OpenSourceStack/SitePages/OSS2-Standard-and-Guidelines.aspx
OSS2_REPLICA_COUNT=2

POD_RESOURCES_LIMITS_CPU=250m
POD_RESOURCES_LIMITS_MEMORY=300Mi
POD_RESOURCES_REQUESTS_CPU=150m
POD_RESOURCES_REQUESTS_MEMORY=200Mi



RUNTIME_ENV=dev

# Use Mongo (real data) for applications + portfolio instead of the in-memory seed.
# Only engages if a Mongo URL is also present (injected via Vault); otherwise falls back to seed.
USE_REAL_DATA=true


# Bearer token guarding the internal Datadog sync endpoint (POST /api/v1/internal/sync/datadog).
# Internal-only (no Okta);

# Scope the portfolio tree to specific Operating Companies (comma-separated, case-insensitive).
# "Mercer for now" (Anand, 2026-06-18). Empty/unset = show all OpCos. Changing this needs a redeploy.
# NOTE: confirm the exact OpCo value in the PlanView data matches "Mercer".
PORTFOLIO_OPCO_ALLOWLIST=Mercer

USE_FRAMEGUARD_MIDDLEWARE=true
USE_HSTS_MIDDLEWARE=true
SERVICE_TYPE=njs
WORKLOAD_KIND=Deployment

DEPLOYMENT_VALUES_FILE=./deployments/helm/aws-api.yml