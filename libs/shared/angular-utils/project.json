{
    "name": "shared-angular-utils",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "projectType": "library",
    "sourceRoot": "libs/shared/angular-utils/src",
    "prefix": "polaris",
    "tags": [],
    "targets": {
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": ["{workspaceRoot}/coverage/libs/shared/angular-utils"],
            "options": {
                "jestConfig": "libs/shared/angular-utils/jest.config.js"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "outputs": ["{options.outputFile}"],
            "options": {
                "lintFilePatterns": [
                    "libs/shared/angular-utils/**/*.ts",
                    "libs/shared/angular-utils/**/*.html"
                ]
            }
        }
    }
}
