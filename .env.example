# Local/dev credentials for the live-health crawler. NEVER commit real values.
# Copy this file to .env (which is gitignored) and fill in the blanks.

# Your Datadog region, taken from the URL when you are logged in:
#   app.datadoghq.com   -> datadoghq.com         (US1, default)
#   us3.datadoghq.com   -> us3.datadoghq.com
#   us5.datadoghq.com   -> us5.datadoghq.com
#   app.datadoghq.eu    -> datadoghq.eu
#   ap1.datadoghq.com   -> ap1.datadoghq.com
DATADOG_SITE=datadoghq.com

# Datadog API key (org-level). Reuse the project key Anton sent Prashant, or create one
# under Organization Settings -> API Keys (needs api_keys_write).
DATADOG_API_KEY=

# Datadog Application key (your user). Create under your avatar -> Personal Settings ->
# Application Keys -> New Key. Scope it to at least monitors_read + slos_read if your org
# uses scoped keys; otherwise it inherits your read permissions.
DATADOG_APP_KEY=

# Shared secret the crawler uses to call the internal sync endpoint.
# Any strong random string for local dev (e.g. `openssl rand -hex 24`).
INTERNAL_SYNC_TOKEN=
